@page "/transactions"
@using CardZen.Models
@using CardZen.Services
@using CardZen.Components.Transactions
@inject ICardService CardService
@inject ITransactionService TransactionService
@inject ToastService ToastService
<HeadContent>
    <style>
        html, body { overflow-y: scroll }
    </style>
</HeadContent>

<div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-10">
        <div class="lg:col-span-5 order-1">
            <TransactionForm 
                TransactionToEdit="SelectedTransaction" 
                OnTransactionUpdated="OnTransactionUpdated"
                OnCancelEdit="OnCancelEdit"
                CardList="CardList"
                CategoryList="CategoryList"
                MccList="MccList"
            />
        </div>
        <div class="lg:col-span-7 order-2 px-4 sm:px-0">
            <TransactionList @ref="transactionListRef" TTxn=TransactionModel 
                CardList="CardList" 
                CategoryList="CategoryList" 
                OnSelectTransaction="OnSelectTransaction" 
                OnCopyTransaction="OnCopyTransaction"
                OnTransactionDeleted="OnTransactionDeleted"
            />
        </div>
    </div>
</div>

@code {
    private TransactionModel? SelectedTransaction;
    private List<CardModel> CardList { get; set; } = new();
    private List<SelectOption> CategoryList { get; set; } = new();
    private List<SelectOption> MccList { get; set; } = new();
    private CardZen.Components.Transactions.TransactionList<TransactionModel>? transactionListRef;

    protected override async Task OnInitializedAsync()
    {
        var cardsResp = await CardService.GetCardsAsync();
        if (cardsResp.Status && cardsResp.Data != null)
            CardList = cardsResp.Data;

        var masterResp = await CardService.GetInitialDataAsync();
        if (masterResp.Status && masterResp.Data != null)
        {
            CategoryList = masterResp.Data.SpendingCategories;
            MccList = masterResp.Data.MccList;
        }
    }


    private void OnSelectTransaction(TransactionModel txn)
    {
        SelectedTransaction = txn;
        StateHasChanged();
    }

    private void OnCopyTransaction(TransactionModel txn)
    {
        // Fill form với bản copy, không có Id => sẽ là thêm mới
        SelectedTransaction = new TransactionModel
        {
            CardId = txn.CardId,
            Amount = txn.Amount,
            CashbackAmount = txn.CashbackAmount,
            Category = txn.Category,
            Date = txn.Date,
            Mcc = txn.Mcc,
            Note = txn.Note,
            Type = txn.Type
        };
        StateHasChanged();
    }

    private void OnTransactionDeleted()
    {
        // Sau khi xóa, reset form và reload danh sách nếu cần
        SelectedTransaction = null;
        StateHasChanged();
    }

    private async void OnTransactionUpdated()
    {
        // Sau khi update, reset form và reload danh sách nếu cần
        SelectedTransaction = null;
        if (transactionListRef != null)
        {
            await transactionListRef.ReloadTransactions();
        }
        StateHasChanged();
    }

    private void OnCancelEdit()
    {
        SelectedTransaction = null;
        StateHasChanged();
    }
}
