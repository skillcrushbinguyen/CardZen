@page "/cards"
@using CardZen.Models
@using CardZen.Services
@inject ICardService CardService
@inject CardZen.Services.ToastService ToastService

<div class="p-8">
    <div class="flex flex-col sm:row justify-between items-start sm:items-center mb-8 gap-4">
        <div>
            <h2 class="text-3xl font-black text-base-content tracking-tight">CardZen Cards</h2>
            <p class="text-sm text-base-content/60 font-medium italic">Quản lý hạn mức và chu kỳ thanh toán</p>
        </div>
        @if (IsAdmin)
        {
            <button @onclick="OpenCreateModal" class="w-full sm:w-auto bg-primary text-primary-content px-8 py-3 rounded-xl font-bold shadow-xl active:scale-95 transition-all">
                + THÊM THẺ MỚI
            </button>
        }
    </div>

    @if (IsLoading)
    {
        <div class="flex justify-center p-12">
            <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-primary"></div>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var card in CardList)
            {
                <CardItem Card="@card" OnEditRequested="() => OpenEditModal(card)" />
            }
        </div>
    }
</div>

@* Modal Component Integration *@
<CardModal IsVisible="IsModalVisible" 
           Card="EditingCard" 
           MasterData="CachedMasterData"
           OnClose="CloseModal" 
           OnSave="HandleSaveCard" />
@code {
    private bool IsAdmin = true;
    private List<CardModel> CardList = new();
    private MasterData CachedMasterData = new();
    private CardModel EditingCard = new();
    private bool IsModalVisible = false;
    private bool IsLoading = true;

    protected override async Task OnInitializedAsync()
    {
        // Tải song song MasterData và CardList để tối ưu tốc độ
        await Task.WhenAll(LoadMasterData(), LoadCards());
        IsLoading = false;
    }

    private async Task LoadMasterData()
    {
        var response = await CardService.GetInitialDataAsync();
        if (response.Status && response.Data != null)
        {
            CachedMasterData = response.Data;
        }
    }

    private async Task LoadCards()
    {
        var response = await CardService.GetCardsAsync();
        if (response.Status)
        {
            CardList = response.Data ?? new();
        }
    }

    private void OpenCreateModal()
    {
        EditingCard = new CardModel { Status = "Active" }; // Reset object cho thẻ mới
        IsModalVisible = true;
    }

    private void OpenEditModal(CardModel card)
    {
        // Clone object để tránh binding trực tiếp làm thay đổi list khi chưa nhấn Save[cite: 1]
        EditingCard = new CardModel 
        { 
            Id = card.Id,
            Name = card.Name,
            Bank = card.Bank,
            Limit = card.Limit,
            StatementDate = card.StatementDate,
            GracePeriod = card.GracePeriod,
            AnnualFeeAmount = card.AnnualFeeAmount,
            AnnualFeeDate = card.AnnualFeeDate,
            IsPaid = card.IsPaid,
            HasOffer = card.HasOffer,
            FeeNote = card.FeeNote,
            Status = card.Status,
            BenefitsList = card.BenefitsList.Select(b => new BenefitItem 
            { 
                MccGroup = b.MccGroup, 
                Rate = b.Rate, 
                CatLimit = b.CatLimit, 
                IsActive = b.IsActive, 
                GlobalLimit = b.GlobalLimit, 
                MinSpendReq = b.MinSpendReq 
            }).ToList()
        };
        IsModalVisible = true;
    }

    private void CloseModal() => IsModalVisible = false;

    private async Task HandleSaveCard(CardModel card)
    {
        IsLoading = true;
        var response = await CardService.SaveCardAsync(card);
        if (response.Status)
        {
            Console.WriteLine($"Card saved successfully: {response.Message}");
            IsModalVisible = false;
            await LoadCards();
            ToastService.ShowToast("Lưu thẻ thành công!", "#22c55e");
        }
        else
        {
            ToastService.ShowToast($"Lỗi: {response.Error}", "#ef4444");
        }
        IsLoading = false;
    }
}