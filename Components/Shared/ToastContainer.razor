@inject CardZen.Services.ToastService ToastService

<div class="fixed top-6 right-6 z-[9999] flex flex-col gap-2">
    @foreach (var toast in ToastService.Toasts)
    {
        <div class="px-4 py-3 rounded-lg shadow-lg text-white font-bold animate-fade-in-up transition-all duration-300"
             style="background:@toast.Background; min-width:220px; max-width:320px;"
             @onclick="() => ToastService.RemoveToast(toast.Id)">
            @toast.Message
        </div>
    }
</div>

@code {
    protected override void OnInitialized()
    {
        ToastService.OnToastsUpdated += StateHasChanged;
    }
    public void Dispose()
    {
        ToastService.OnToastsUpdated -= StateHasChanged;
    }
}