
@using CardZen.Models
@* Dropdown chọn danh mục chi tiêu với icon *@
<select class="form-select w-full py-2 px-3 rounded-xl border border-slate-200 bg-white text-sm font-bold text-slate-700 flex items-center" @onchange="OnChange" value="@SelectedValue">
    <option value="">Chọn danh mục</option>
    @if (Categories != null)
    {
        @foreach (var cat in Categories)
        {
            <option value="@cat.Value">
                @cat.Icon @cat.Value
            </option>
        }
    }
</select>

@code {
    [Parameter] public List<SelectOption>? Categories { get; set; }
    [Parameter] public string? SelectedValue { get; set; }
    [Parameter] public EventCallback<string> SelectedValueChanged { get; set; }

    private async Task OnChange(ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? string.Empty;
        if (SelectedValue != value)
        {
            SelectedValue = value;
            await SelectedValueChanged.InvokeAsync(value);
        }
    }
}
