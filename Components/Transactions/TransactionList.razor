@using System.Diagnostics
@inject ITransactionService TransactionService
@inject ToastService ToastService
@inject Microsoft.JSInterop.IJSRuntime JSRuntime
@typeparam TTxn
<div>
    <h2 class="text-xl font-bold mb-4">Danh sách giao dịch</h2>
    @if (IsLoading)
    {
        <div>Đang tải dữ liệu...</div>
    }
    else if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="text-error">@ErrorMessage</div>
    }
    else if (Transactions.Count == 0)
    {
        <div>Chưa có giao dịch nào.</div>
    }
    else
    {
        <div class="h-virtualize">
            <Virtualize Items="Transactions" Context="txn" ItemSize="114 + 16">
                <ItemContent>
                    <TransactionItem 
                        Transaction="txn"
                        CardList="CardList"
                        CategoryList="CategoryList"
                        IsLoading="IsLoading"
                        IsDeleting="DeletingId == txn.Id"
                        OnEditClick="() => OnEditClick(txn)"
                        OnCopyClick="() => OnCopyClick(txn)"
                        OnDeleteClick="() => OnDeleteClick(txn)" />
                </ItemContent>
            </Virtualize>
        </div>
    }
</div>
                

@code {
    private int _lastSwipeCount = 0;
    private List<TransactionModel> Transactions { get; set; } = new List<TransactionModel>();
    private bool IsLoading = true;
    private string? ErrorMessage;
    private string? DeletingId = null;

    [Parameter] public EventCallback<TransactionModel> OnSelectTransaction { get; set; }
    [Parameter] public EventCallback<TransactionModel> OnCopyTransaction { get; set; }
    [Parameter] public EventCallback OnTransactionDeleted { get; set; }
    [Parameter] public List<CardModel> CardList { get; set; } = new();
    [Parameter] public List<SelectOption> CategoryList { get; set; } = new();

    private async void OnEditClick(TransactionModel txn)
    {
        await OnSelectTransaction.InvokeAsync(txn);
        await ResetSwipeState(txn.Id);
        await JSRuntime.InvokeVoidAsync("cardzenSwipe.scrollToTop");
    }
    private async void OnCopyClick(TransactionModel txn)
    {
        await OnCopyTransaction.InvokeAsync(new TransactionModel
        {
            CardId = txn.CardId,
            Amount = txn.Amount,
            CashbackAmount = txn.CashbackAmount,
            Category = txn.Category,
            Date = txn.Date,
            Mcc = txn.Mcc,
            Note = txn.Note,
            Type = txn.Type
        });
        await ResetSwipeState(txn.Id);
        await JSRuntime.InvokeVoidAsync("cardzenSwipe.scrollToTop");
    }
    private async void OnDeleteClick(TransactionModel txn)
    {
        await OnDeleteTransaction(txn);
        await ResetSwipeState(txn.Id);
    }

    private async Task ResetSwipeState(string txnId)
    {
        // Gọi JS để remove class 'swiped' khỏi item tương ứng
        await JSRuntime.InvokeVoidAsync("cardzenSwipe.resetSwipe", txnId);
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var resp = await TransactionService.GetTransactionsAsync();
            if (resp.Status && resp.Data != null)
            {
                Transactions = resp.Data;
            }
            else
            {
                ErrorMessage = resp.Error ?? "Không thể tải dữ liệu giao dịch.";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        IsLoading = false;
    }

    private DotNetObjectReference<TransactionList<TTxn>>? _dotNetRef;
    protected override void OnAfterRender(bool firstRender)
    {
        int swipeCount = Transactions?.Count ?? 0;
        if (swipeCount != _lastSwipeCount || firstRender)
        {
            try
            {
                _dotNetRef ??= DotNetObjectReference.Create(this);
                var jsInProcess = JSRuntime as IJSInProcessRuntime;
                if (jsInProcess != null)
                {
                    jsInProcess.InvokeVoid("cardzenSwipe.registerSwipeActions", ".swipeable-item", ".swipe-actions", _dotNetRef);
                }
                else
                {
                    JSRuntime.InvokeVoidAsync("cardzenSwipe.registerSwipeActions", ".swipeable-item", ".swipe-actions", _dotNetRef).AsTask().Wait();
                }
            }
            catch { }
            _lastSwipeCount = swipeCount;
        }
    }

    [JSInvokable]
    public void OnSwipe(string direction, string txnId)
    {
        Console.WriteLine($"[SWIPE] direction={direction}, txnId={txnId}");
    }

    public async Task ReloadTransactions()
    {
        IsLoading = true;
        StateHasChanged();
        try
        {
            var resp = await TransactionService.GetTransactionsAsync();
            if (resp.Status && resp.Data != null)
            {
                Transactions = resp.Data;
            }
            else
            {
                ErrorMessage = resp.Error ?? "Không thể tải dữ liệu giao dịch.";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        IsLoading = false;
        StateHasChanged();
    }
    
    private async Task OnDeleteTransaction(TransactionModel txn)
    {
        if (!await ConfirmDelete(txn)) return;
        try
        {
            DeletingId = txn.Id;
            StateHasChanged();
            
            var resp = await TransactionService.DeleteTransactionAsync(txn.Id);
            if (resp.Status)
            {
                ToastService.ShowSuccess("Giao dịch đã được xóa!");
                await OnTransactionDeleted.InvokeAsync();
                await ReloadTransactions();
                StateHasChanged();
            }
            else
            {
                ErrorMessage = resp.Error ?? "Xóa giao dịch thất bại.";
                ToastService.ShowError(ErrorMessage);
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
            ToastService.ShowError(ErrorMessage);
        }
        finally
        {
            DeletingId = null;
            StateHasChanged();
        }
    }

    private async Task<bool> ConfirmDelete(TransactionModel txn)
    {
        // Dùng JS confirm đơn giản
        return await JSRuntime.InvokeAsync<bool>("confirm", $"Bạn có chắc muốn xóa giao dịch {txn.Amount:N0}đ ngày {txn.Date:dd/MM/yyyy}?");
    }
}
