@using CardZen.Models

<ModalContainer IsVisible="IsVisible" OnClose="Close" MaxWidthClass="max-w-3xl">
    @* Header *@
    <div class="modal-header flex justify-between items-center">
        <div>
            <h3 class="text-xl font-black text-base-content uppercase tracking-tight">
                @(IsEditMode ? "Cấu hình chi tiết thẻ" : "Phát hành thẻ mới")
            </h3>
            <p class="text-xs text-primary font-black uppercase tracking-widest mt-1">
                CardZen Management System Console
            </p>
        </div>
        <button @onclick="Close" class="btn btn-ghost btn-sm rounded-full">
            <i class="material-icons text-base-content">close</i>
        </button>
    </div>

    @* Body *@
    <div class="p-6 overflow-y-auto flex-1 space-y-8">
        @* Section 1: Thông tin định danh (Dạng Text Input như code cũ) *@
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="form-control">
                <label class="label">
                    <span class="label-text text-xs font-black uppercase">Tên hiển thị</span>
                </label>
                <input @bind="Card.Name" class="input input-bordered w-full font-bold" placeholder="VD: VIB Super Card" />
            </div>
            <div class="form-control">
                <label class="label">
                    <span class="label-text text-xs font-black uppercase">Ngân hàng phát hành</span>
                </label>
                <input @bind="Card.Bank" class="input input-bordered w-full font-bold uppercase" placeholder="VD: VIB, VPBANK..." />
            </div>
        </div>

        @* Section 2: Chu kỳ thanh toán & Hạn mức *@
        <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
            <div class="form-control">
                <label class="label">
                    <span class="label-text text-xs font-black uppercase">Ngày chốt sao kê</span>
                </label>
                <input type="number" @bind="Card.StatementDate" min="1" max="31" class="input input-bordered w-full font-bold" />
            </div>
            <div class="form-control">
                <label class="label">
                    <span class="label-text text-xs font-black uppercase">Ngày miễn lãi</span>
                </label>
                <input type="number" @bind="Card.GracePeriod" class="input input-bordered w-full font-bold" />
            </div>
            <CurrencyInput Label="Hạn mức thẻ" @bind-Value="Card.Limit" />
        </div>

        @* Section 3: Phí thường niên & Ghi chú *@
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 p-5 bg-base-200 rounded-3xl border border-base-300">
            <CurrencyInput Label="Phí thường niên" @bind-Value="Card.AnnualFeeAmount" />
            <div class="form-control">
                <label class="label">
                    <span class="label-text text-xs font-black uppercase">Ngày thu phí</span>
                </label>
                <input type="date" @bind="Card.AnnualFeeDate" class="input input-bordered w-full font-bold" />
            </div>
        </div>

        @* Section 4: Cấu hình Cashback động *@
        <div class="p-6 bg-primary/10 rounded-3xl border border-primary/20 space-y-6">
            @* Cashback Master Switch *@
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="avatar placeholder">
                        <div class="bg-primary text-primary-content rounded-xl w-10 h-10 flex items-center justify-center">
                            <i class="material-icons">loyalty</i>
                        </div>
                    </div>
                    <div>
                        <h4 class="text-sm font-black text-base-content uppercase">Tính năng Cashback</h4>
                        <p class="text-xs font-bold text-primary uppercase">Global Cashback Configuration</p>
                    </div>
                </div>
                <input type="checkbox" @bind="_isCashbackActive" class="toggle toggle-primary" />
            </div>

            @if (_isCashbackActive)
            {
                @* 3 trường Tech Debt: Phản ánh vào 3 input riêng biệt *@
                <div class="grid grid-cols-2 gap-4">
                    <CurrencyInput Label="Hạn mức hoàn tổng (Tháng)" @bind-Value="_globalLimit" />
                    <CurrencyInput Label="Chi tiêu tối thiểu để hoàn" @bind-Value="_minSpendRequest" />
                </div>

                <hr class="border-primary/20" />

                @* Danh sách MCC chi tiết *@
                <MccListEditor Benefits="Card.BenefitsList" MccOptions="MasterData.MccList" />
            }
        </div>
        
        @* Section 5: Trạng thái (Checkboxes)[cite: 1] *@
        <div class="flex flex-wrap gap-8 p-4 bg-base-100 rounded-2xl border border-dashed border-base-300">
            <label class="flex items-center gap-3 cursor-pointer">
                <input type="checkbox" @bind="Card.IsPaid" class="checkbox checkbox-primary" />
                <span class="text-xs font-black uppercase text-base-content">Đã thanh toán dư nợ</span>
            </label>

            <label class="flex items-center gap-3 cursor-pointer">
                <input type="checkbox" @bind="Card.HasOffer" class="checkbox checkbox-secondary" />
                <span class="text-xs font-black uppercase text-base-content">Đã nhận Offer phí</span>
            </label>
            
            <label class="flex items-center gap-3 cursor-pointer">
                <select @bind="Card.Status" class="select select-bordered select-xs font-black uppercase">
                    <option value="Active">Hoạt động</option>
                    <option value="Locked">Đã khóa</option>
                </select>
            </label>
        </div>
    </div>

    @* Footer *@
    <div class="modal-action flex gap-4">
        <button @onclick="Close" class="btn btn-ghost">HỦY BỎ</button>
        <button @onclick="HandleSave" class="btn btn-primary flex-1">XÁC NHẬN LƯU THAY ĐỔI</button>
    </div>
</ModalContainer>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public CardModel Card { get; set; } = new();
    [Parameter] public MasterData MasterData { get; set; } = new();
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<CardModel> OnSave { get; set; }
    
    // Thuộc tính tạm thời để binding trong Modal tránh làm hỏng logic Getter của Model
    private bool _isCashbackActive;
    private long _globalLimit;
    private long _minSpendRequest;
    private bool IsEditMode => !string.IsNullOrEmpty(Card.Id);
    
    protected override void OnParametersSet()
    {
        // Khi Modal mở ra, lấy dữ liệu từ list nạp vào biến tạm
        if (Card.BenefitsList.Any())
        {
            var first = Card.BenefitsList.First();
            _isCashbackActive = first.IsActive;
            _globalLimit = first.GlobalLimit;
            _minSpendRequest = first.MinSpendReq;
        }
    }
    private async Task Close() => await OnClose.InvokeAsync();
    
    private async Task HandleSave()
    {
        // Đồng bộ ngược lại vào list trước khi Save
        if (Card.BenefitsList.Any())
        {
            foreach (var item in Card.BenefitsList)
            {
                item.IsActive = _isCashbackActive;
                item.GlobalLimit = _globalLimit;
                item.MinSpendReq = _minSpendRequest;
            }
        }
        else if (_isCashbackActive) 
        {
            // Nếu là thẻ mới hoàn toàn và bật cashback, tạo ít nhất 1 item mặc định
            Card.BenefitsList.Add(new BenefitItem { 
                IsActive = true, 
                GlobalLimit = _globalLimit, 
                MinSpendReq = _minSpendRequest 
            });
        }

        await OnSave.InvokeAsync(Card);
    }
}