@* MccListEditor.razor *@
@using CardZen.Models

<div class="space-y-4">
    <div class="flex justify-between items-center border-b border-slate-100 pb-2">
        <label class="text-[10px] font-black uppercase text-indigo-500 tracking-widest">Danh mục hoàn tiền chi tiết</label>
        <button @onclick="AddBenefit" type="button" class="text-[10px] font-black text-indigo-600 hover:underline">+ THÊM MCC</button>
    </div>

    @foreach (var item in Benefits)
    {
        <div class="grid grid-cols-12 gap-3 items-center bg-white p-3 rounded-2xl border border-slate-50">
            <div class="col-span-5">
                <select @bind="item.MccGroup" class="w-full bg-slate-50 border-0 rounded-xl font-bold text-xs p-3">
                    <option value="">Chọn nhóm...</option>
                    @foreach (var opt in MccOptions) { <option value="@opt.Value">@opt.Value</option> }
                </select>
            </div>
            <div class="col-span-3 relative">
                <input type="number" @bind="item.Rate" class="w-full bg-slate-50 border-0 rounded-xl font-bold text-xs p-3 text-center" />
                <span class="absolute right-2 top-1/2 -translate-y-1/2 text-[9px] font-bold text-slate-300">%</span>
            </div>
            <div class="col-span-3">
                <input type="number" @bind="item.CatLimit" class="w-full bg-slate-50 border-0 rounded-xl font-bold text-[10px] p-3" placeholder="Hạn mức" />
            </div>
            <div class="col-span-1 text-right">
                <button @onclick="() => Benefits.Remove(item)" class="text-red-300 hover:text-red-500"><i class="material-icons text-sm">delete</i></button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public List<BenefitItem> Benefits { get; set; } = new();
    [Parameter] public List<SelectOption> MccOptions { get; set; } = new();
    private void AddBenefit() => Benefits.Add(new BenefitItem { IsActive = true });
}