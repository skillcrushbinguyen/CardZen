@* MccListEditor.razor *@
@using CardZen.Models

<div class="space-y-4">
    <div class="flex justify-between items-center border-b border-base-300 pb-2">
        <label class="text-[10px] font-black uppercase text-primary tracking-widest">Danh mục hoàn tiền chi tiết</label>
        <button @onclick="AddBenefit" type="button" class="btn btn-sm btn-ghost text-primary">+ THÊM MCC</button>
    </div>

    @foreach (var item in Benefits)
    {
        <div class="grid grid-cols-12 gap-3 items-center bg-base-100 p-3 rounded-2xl border border-base-200">
            <div class="col-span-5">
                <select @bind="item.MccGroup" class="select select-bordered select-sm w-full font-bold">
                    <option value="">Chọn nhóm...</option>
                    @foreach (var opt in MccOptions) { <option value="@opt.Value">@opt.Value</option> }
                </select>
            </div>
            <div class="col-span-3 relative">
                <input type="number" @bind="item.Rate" class="input input-bordered input-sm w-full font-bold text-center" />
                <span class="absolute right-2 top-1/2 -translate-y-1/2 text-[9px] font-bold text-base-content/30">%</span>
            </div>
            <div class="col-span-3">
                <input type="number" @bind="item.CatLimit" class="input input-bordered input-sm w-full font-bold" placeholder="Hạn mức" />
            </div>
            <div class="col-span-1 text-right">
                <button @onclick="() => Benefits.Remove(item)" class="btn btn-ghost btn-sm text-error"><i class="material-icons text-sm">delete</i></button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public List<BenefitItem> Benefits { get; set; } = new();
    [Parameter] public List<SelectOption> MccOptions { get; set; } = new();
    private void AddBenefit() => Benefits.Add(new BenefitItem { IsActive = true });
}