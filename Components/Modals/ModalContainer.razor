@* ModalContainer.razor *@
@if (IsVisible)
{
    <div class="fixed inset-0 z-[100] flex items-center justify-center p-4 sm:p-6 overflow-hidden">
        @* Backdrop Overlay *@
        <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm transition-opacity" 
             @onclick="HandleBackdropClick"></div>

        @* Modal Content Container *@
        <div class="relative bg-white w-full @MaxWidthClass rounded-3xl shadow-2xl overflow-hidden flex flex-col max-h-[90vh] z-10 animate-in fade-in zoom-in duration-300">
            @ChildContent
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string MaxWidthClass { get; set; } = "max-w-2xl";
    [Parameter] public bool CloseOnBackdropClick { get; set; } = true;
    [Parameter] public EventCallback OnClose { get; set; }

    private async Task HandleBackdropClick()
    {
        if (CloseOnBackdropClick)
        {
            await OnClose.InvokeAsync();
        }
    }
}