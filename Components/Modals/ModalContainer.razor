@* DaisyUI Modal dùng <dialog> và modal-open, không checkbox hack *@
<dialog class="modal @(IsVisible ? "modal-open" : null)">
    <div class="modal-box @MaxWidthClass" @onclick:stopPropagation="true">
        @ChildContent
    </div>
    <div class="modal-backdrop" @onclick="HandleBackdropClick"></div>
</dialog>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string MaxWidthClass { get; set; } = "max-w-2xl";
    [Parameter] public bool CloseOnBackdropClick { get; set; } = true;
    [Parameter] public EventCallback OnClose { get; set; }

    private async Task HandleBackdropClick()
    {
        if (CloseOnBackdropClick)
        {
            await OnClose.InvokeAsync();
        }
    }
}