@* File: Shared/MainLayout.razor *@
@inherits LayoutComponentBase

<div class="min-h-screen flex flex-col">
    <!-- DaisyUI Navbar Top -->
    <div class="navbar bg-base-200 shadow-lg sticky top-0 z-30">
        <div class="navbar-start">
            <a href="/" class="flex items-center gap-2 pl-4">
                <div class="w-10 h-10 bg-primary rounded-lg flex items-center justify-center">
                    <i class="material-icons text-primary-content">account_balance_wallet</i>
                </div>
                <span class="text-xl font-bold text-base-content">CardZen</span>
            </a>
        </div>
        <!-- Desktop Menu Center -->
        <div class="navbar-center hidden md:flex">
            <ul class="menu menu-horizontal px-1 gap-1">
                <li>
                    <NavLink href="" Match="NavLinkMatch.All" class="font-bold">
                        <i class="material-icons text-lg">dashboard</i>
                        Tổng quan
                    </NavLink>
                </li>
                <li>
                    <NavLink href="cards" class="font-bold">
                        <i class="material-icons text-lg">credit_card</i>
                        Ví thẻ
                    </NavLink>
                </li>
                <li>
                    <NavLink href="transactions" class="font-bold">
                        <i class="material-icons text-lg">receipt_long</i>
                        Giao dịch
                    </NavLink>
                </li>
            </ul>
        </div>
        <div class="navbar-end pr-4">
            <button class="btn btn-ghost btn-circle">
                <i class="material-icons">notifications</i>
            </button>
        </div>
    </div>

    <!-- Main Content -->
    <main class="flex-1 container mx-auto px-4 py-5 pb-24 md:py-6 md:pb-6">
        @Body
    </main>

    <!-- Mobile Bottom Navigation (DaisyUI Dock) -->
    <div class="dock dock-lg fixed bottom-0 left-0 right-0 md:hidden z-40 bg-base-200 border-t border-base-300">
        <NavLink href="" Match="NavLinkMatch.All">
            <i class="material-icons text-2xl">dashboard</i>
            <span class="dock-label">Tổng quan</span>
        </NavLink>
        <NavLink href="cards">
            <i class="material-icons text-2xl">credit_card</i>
            <span class="dock-label">Ví thẻ</span>
        </NavLink>
        <NavLink href="transactions">
            <i class="material-icons text-2xl">receipt_long</i>
            <span class="dock-label">Giao dịch</span>
        </NavLink>
    </div>

    <!-- Toast Notification -->
    <ToastContainer />
</div>