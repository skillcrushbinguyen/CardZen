<!-- DaisyUI Drawer Nav (Mobile/Tablet) -->
<div class="drawer z-50">
    <input id="nav-drawer" type="checkbox" class="drawer-toggle" @bind="collapseNavMenu" />
    <div class="drawer-content">
        <label for="nav-drawer" class="btn btn-ghost btn-square md:hidden m-2">
            <i class="fas fa-bars"></i>
        </label>
        <!-- Navbar (visible on mobile/tablet) -->
        <div class="navbar bg-base-100 md:hidden">
            <div class="flex-1">
                <span class="text-lg font-bold">CardZen</span>
            </div>
        </div>
    </div>
    <div class="drawer-side">
        <label for="nav-drawer" class="drawer-overlay"></label>
        <aside class="menu p-4 w-64 min-h-full bg-base-200 text-base-content">
            <h2 class="font-black text-xl mb-4">Menu</h2>
            <ul>
                <li><NavLink href="" Match="NavLinkMatch.All" class="font-bold" @onclick="ToggleNavMenu"><i class="fas fa-home mr-2"></i>Home</NavLink></li>
                <li><NavLink href="counter" class="font-bold" @onclick="ToggleNavMenu"><i class="fas fa-plus-square mr-2"></i>Counter</NavLink></li>
                <li><NavLink href="weather" class="font-bold" @onclick="ToggleNavMenu"><i class="fas fa-list mr-2"></i>Weather</NavLink></li>
            </ul>
        </aside>
    </div>
</div>

@code {
    private bool collapseNavMenu = false;
    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
